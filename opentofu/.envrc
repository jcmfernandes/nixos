source_up
use devenv

# Pull tofu credentials out of secrets/infra.yaml so plan/apply in this tree
# just works. Provides:
# - TF_ENCRYPTION: wraps the state-encryption passphrase (PBKDF2 + AES-GCM).
# - AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY: IONOS S3 keys for the remote
#   state backend (the s3 backend uses AWS_* env var names regardless of
#   provider).
# Yubikey touch is cached, so the three sops calls only prompt once.
# Direnv caches the result so this re-runs only on .envrc / devenv changes.
if command -v sops >/dev/null 2>&1; then
  _secrets_file="$PWD/../secrets/infra.yaml"
  if _pass="$(sops --extract '["opentofu_state_passphrase"]' --decrypt "$_secrets_file" 2>/dev/null)"; then
    export TF_ENCRYPTION="$(printf 'key_provider "pbkdf2" "passphrase" {\n  passphrase = "%s"\n}\n' "$_pass")"
    export AWS_ACCESS_KEY_ID="$(sops --extract '["ionos_s3_access_key"]' --decrypt "$_secrets_file")"
    export AWS_SECRET_ACCESS_KEY="$(sops --extract '["ionos_s3_secret_key"]' --decrypt "$_secrets_file")"
  fi
  unset _pass _secrets_file
fi
